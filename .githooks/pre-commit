#!/bin/sh
# Auto-rebuild semantic search index + embeddings when source changes.

# Temporarily disabled for Section 12 M3 — restored at Task 15 via
# `git checkout -- .githooks/pre-commit` + `npm run search:build`.
exit 0

set -e

# Detect whether anything that affects the search index is staged.
RELEVANT=$(git diff --cached --name-only -- 'src/sections/*.jsx' 'src/sections/*.js' 'src/config.js' 'src/data/svg-descriptions.json' 'public/models/*/model-meta.json' || true)

if [ -z "$RELEVANT" ]; then
  # Nothing source-side changed: still verify in-tree consistency.
  node scripts/check-embeddings.mjs
  exit 0
fi

if ! command -v claude >/dev/null 2>&1; then
  echo "\033[31m[pre-commit] claude CLI not found in PATH. Source files changed; cannot rebuild search index.\033[0m"
  exit 1
fi

echo "\033[33m[pre-commit] Source changed. Rebuilding search index + embeddings via claude CLI...\033[0m"
npm run search:build --silent

# Stage every regenerated artifact + cache.
git add src/data/chunks.json src/data/chunk-cache.json src/data/embeddings.bin src/data/embeddings-manifest.json

node scripts/check-embeddings.mjs
echo "\033[32m[pre-commit] Search index + embeddings up to date.\033[0m"
