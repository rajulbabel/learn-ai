#!/bin/sh
# Auto-sync embeddings with chunks before committing

# First check if they're already in sync
node scripts/check-embeddings.mjs 2>/dev/null
if [ $? -ne 0 ]; then
  echo "\033[33m[pre-commit] Embeddings out of sync. Rebuilding...\033[0m"
  npm run search:build
  if [ $? -ne 0 ]; then
    echo "\033[31m[pre-commit] search:build failed. Commit aborted.\033[0m"
    exit 1
  fi
  echo "\033[32m[pre-commit] Embeddings rebuilt.\033[0m"
fi

# Always stage embedding data files if they have modifications,
# so they never get left behind as unstaged changes
for f in src/data/chunks.json src/data/embeddings.json src/data/embeddings-checksum.json; do
  if [ -n "$(git diff --name-only "$f" 2>/dev/null)" ]; then
    git add "$f"
  fi
done
