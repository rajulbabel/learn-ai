{
  "name": "learn-ai",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "npm run search:extract && vite build",
    "preview": "vite preview",
    "lint": "eslint src/",
    "format": "prettier --write src/",
    "test": "vitest run",
    "test:watch": "vitest",
    "search:extract": "vitest run scripts/extract-content.test.jsx",
    "search:embed": "node scripts/generate-embeddings.mjs",
    "search:build": "npm run search:extract && npm run search:embed",
    "search:check": "node scripts/check-embeddings.mjs",
    "prepare": "node scripts/install-hooks.mjs"
  },
  "dependencies": {
    "@huggingface/transformers": "^3.8.1",
    "minisearch": "^7.2.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/coverage-v8": "^4.1.0",
    "eslint": "^10.0.3",
    "globals": "^17.4.0",
    "jsdom": "^28.1.0",
    "prettier": "^3.8.1",
    "vite": "^6.2.0",
    "vitest": "^4.1.0"
  }
}
