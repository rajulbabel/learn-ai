{
  "name": "learn-ai",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "prod": "concurrently -k -n build,serve -c yellow,cyan \"vite build --watch\" \"vite preview\"",
    "lint": "eslint src/",
    "format": "prettier --write src/",
    "test": "vitest run --coverage",
    "test:watch": "vitest",
    "search:index": "node scripts/build-search-index.mjs",
    "search:embed": "node scripts/embed-chunks-remote.mjs",
    "search:build": "npm run search:index && npm run search:embed",
    "search:check": "node scripts/check-embeddings.mjs",
    "og": "node scripts/generate-og.mjs",
    "favicons": "node scripts/generate-favicons.mjs",
    "prepare": "git config core.hooksPath .githooks"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.91.1",
    "dotenv": "^17.4.2",
    "minisearch": "^7.2.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@resvg/resvg-js": "^2.6.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/coverage-v8": "^4.1.0",
    "concurrently": "^9.2.1",
    "eslint": "^10.0.3",
    "globals": "^17.4.0",
    "jsdom": "^28.1.0",
    "prettier": "^3.8.1",
    "vite": "^6.2.0",
    "vitest": "^4.1.0"
  }
}
